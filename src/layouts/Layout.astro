---
import "../styles/global.css";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer.astro";
import ModalController from "../components/ModalController";

const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gtmContainerId = import.meta.env.PUBLIC_GTM_ID;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>Autoescola Ideal Jales - CNH RÃ¡pida e PreÃ§o Justo</title>
    <meta
      name="description"
      content="Tire sua carteira de motorista com a Autoescola Ideal em Jales. PreÃ§o justo, instrutores qualificados e agendamento fÃ¡cil."
    />

    {gtmContainerId ? (
      <script is:inline>
        {`
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','${gtmContainerId}');
        `}
      </script>
    ) : null}

    {gaMeasurementId ? (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', '${gaMeasurementId}');
          `}
        </script>
      </>
    ) : null}

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,1,0"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      set:html={`{
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Auto Escola Ideal",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Centro, 2264",
        "addressLocality": "Jales",
        "addressRegion": "SP",
        "postalCode": "15700-000",
        "addressCountry": "BR"
      },
      "url": "https://seusite.com",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -20.271587,
        "longitude": -50.5503057
      }
    }`}
    />
  </head>

  <body class="flex flex-col site-shell">
    {gtmContainerId ? (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmContainerId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    ) : null}
    <a class="skip-link" href="#conteudo-principal">Pular para o conteÃºdo</a>
    <Navbar client:load />
    <main id="conteudo-principal" class="site-main flex flex-col gap-0">
      <slot />
      <a
        href="https://wa.me/5517997572900"
        data-lead-source="floating-whatsapp"
        class="floating-whatsapp fixed bottom-4 right-4 z-50 inline-flex h-14 w-14 items-center justify-center overflow-hidden rounded-full bg-green-500 text-white transition-colors duration-300 hover:bg-green-600 sm:bottom-5 sm:right-5 sm:h-15 sm:w-15"
        role="button"
        target="_blank"
        aria-label="Fale conosco pelo WhatsApp"
        title="Abrir WhatsApp"
      >
        <img
          src="/icone-whatsapp.jpg"
          alt="WhatsApp"
          class="h-full w-full object-cover"
        />
      </a>
    </main>
    <ModalController client:load />

    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline src="../javascript/scripts.js"></script>
<script is:inline src="../javascript/analytics.js"></script>
