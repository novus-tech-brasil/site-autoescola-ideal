---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen material-surface">
    <!-- Hero Section -->
    <section class="px-4 md:px-6 py-12 md:py-16 material-surface border-b border-[#071CF8]/10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">
          Cursos Especializantes
        </h1>
        <p class="text-base md:text-lg text-slate-700">
          Amplie suas habilidades com cursos certificados
        </p>
      </div>
    </section>

    <!-- Grid de Cursos -->
    <section class="px-4 md:px-6 py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Curso 1 -->
          <a href="/cursos/transporte-cargas-indivisiveis">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#071CF8] to-[#041092] flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-5xl">local_shipping</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Cargas Indivisíveis</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Transporte especializado de cargas grandes.</p>
                <div class="text-2xl font-black text-[#071CF8] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#071CF8] hover:bg-[#041092] text-white text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>

          <!-- Curso 2 -->
          <a href="/cursos/transporte-emergencial">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#071CF8] to-[#041092] flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-5xl">emergency</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Emergencial</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Condução segura de veículos de emergência.</p>
                <div class="text-2xl font-black text-[#071CF8] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#071CF8] hover:bg-[#041092] text-white text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>

          <!-- Curso 3 -->
          <a href="/cursos/direcao-defensiva">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#071CF8] to-[#041092] flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-5xl">shield_person</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Direção Defensiva</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Técnicas avançadas de direção segura.</p>
                <div class="text-2xl font-black text-[#071CF8] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#071CF8] hover:bg-[#041092] text-white text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>

          <!-- Curso 4 -->
          <a href="/cursos/legislacao-transito">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#071CF8] to-[#041092] flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-5xl">gavel</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Legislação</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Domínio completo das leis de trânsito.</p>
                <div class="text-2xl font-black text-[#071CF8] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#071CF8] hover:bg-[#041092] text-white text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>

          <!-- Curso 5 -->
          <a href="/cursos/manobras-especializadas">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#FFCB00] to-[#e6b800] flex items-center justify-center">
                <span class="material-symbols-outlined text-black text-5xl">settings</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Manobras</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Domine manobras complexas e desafiadoras.</p>
                <div class="text-2xl font-black text-[#7a5800] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#FFCB00] hover:bg-[#e6b800] text-[#071CF8] text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>

          <!-- Curso 6 -->
          <a href="/cursos/eficiencia-combustivel">
            <div class="md-card rounded-md overflow-hidden border border-[#071CF8]/10 h-full flex flex-col hover:border-[#FFCB00] transition">
              <div class="h-32 md:h-40 bg-linear-to-br from-[#FFCB00] to-[#e6b800] flex items-center justify-center">
                <span class="material-symbols-outlined text-black text-5xl">eco</span>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-gray-900 mb-2">Eficiência</h3>
                <p class="text-sm text-slate-700 mb-4 flex-1">Economize combustível e dirija consciente.</p>
                <div class="text-2xl font-black text-[#7a5800] mb-2">R$ 285,99</div>
                <p class="text-xs text-slate-700 mb-3"><span class="line-through">R$ 380,00</span> em promoção</p>
                <button class="md-action-btn bg-[#FFCB00] hover:bg-[#e6b800] text-[#071CF8] text-sm font-bold py-2 px-3 rounded transition w-full">Ver Curso</button>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="px-4 md:px-6 py-12 md:py-16 material-hero">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-black text-white mb-4">
          Escolha seu curso agora
        </h2>
        <p class="text-base text-white mb-6">
          Qualidade e preço justo para sua profissionalização
        </p>
        <a
          href="https://wa.me/5517997572900"
          target="_blank"
          class="md-action-btn inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-100 text-blue-600 font-bold py-3 px-8 rounded transition"
        >
          <span class="material-symbols-outlined">whatsapp</span>
          Conversar no WhatsApp
        </a>
      </div>
    </section>
  </main>
</Layout>
