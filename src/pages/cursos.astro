---
import Layout from '../layouts/Layout.astro';
import { courses } from '../lib/courses';
import { generateCoursesListSchema } from '../lib/schemas';

const courseSchema = generateCoursesListSchema(courses);
---

<Layout>
  <div>
    <section class="material-hero py-14 md:py-18">
      <div class="section-wrap grid grid-cols-1 gap-4 lg:grid-cols-12">
        <article class="editorial-card col-span-1 bg-[#050f93] p-5 text-white sm:p-6 md:p-9 lg:col-span-8">
          <p class="eyebrow text-[#ffcb00]">Cursos Especializantes</p>
          <h1 class="headline-lg mt-4 text-balance max-w-[16ch] text-white">
            Formação profissional
            <span class="text-[#ffcb00]">com certificação</span>
          </h1>
          <p class="copy-limit text-pretty mt-4 text-base leading-relaxed text-white/95 md:text-lg">
            Cursos para motoristas que buscam atualização técnica, segurança e
            mais oportunidades no mercado.
          </p>
        </article>
        <aside class="editorial-card col-span-1 bg-[#ffcb00] p-5 text-black sm:p-6 md:p-9 lg:col-span-4">
          <p class="text-xs font-bold uppercase tracking-[0.14em]">Atendimento</p>
          <p class="mt-3 text-balance font-['Space_Grotesk'] text-2xl uppercase leading-tight">Tire dúvidas e reserve sua vaga pelo WhatsApp.</p>
        </aside>
      </div>
    </section>

    <section class="material-surface-strong py-14 md:py-18">
      <div class="section-wrap">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {courses.map((course) => (
            <div 
              class="editorial-card flex h-full flex-col overflow-hidden bg-white"
            >
              <div class="relative h-48 overflow-hidden border-b border-[#0f172a]/10 bg-slate-200 md:h-56">
                <img 
                  src={course.img} 
                  alt={course.nome}
                  class="w-full h-full object-cover"
                />
                <div class={`absolute right-4 top-4 rounded-md p-3 text-white ${
                  course.cor === 'primary' ? 'bg-[#0619dd]' : 'bg-[#ff9500]'
                }`}>
                  <span class="material-symbols-outlined">
                    {course.icone}
                  </span>
                </div>
              </div>
              
              <div class="flex flex-1 flex-col p-5 sm:p-6">
                <h3 class="font-['Space_Grotesk'] text-2xl uppercase leading-none text-balance text-[#0c1327]">
                  {course.nome}
                </h3>
                <p class="mt-2 text-sm text-slate-600">
                  {course.titulo}
                </p>
                <p class="mb-4 mt-4 flex-1 text-pretty text-sm text-slate-700">
                  {course.descricao}
                </p>
                
                <div class="mb-4 flex-1">
                  {course.beneficios.map((beneficio) => (
                    <div class="mb-2 flex items-start gap-2">
                      <span class="material-symbols-outlined mt-1 shrink-0 text-sm text-[#0619dd]">
                        done
                      </span>
                      <span class="text-sm text-slate-700">{beneficio}</span>
                    </div>
                  ))}
                </div>

                <div class="mb-6 rounded-md border border-[#0f172a]/10 bg-slate-50 p-4">
                  <p class="mb-1 text-xs text-slate-700 line-through">
                    De {course.precoOriginal}
                  </p>
                  <p class={`text-2xl font-bold mb-1 ${
                    course.cor === 'primary' ? 'text-[#0619dd]' : 'text-[#ff9500]'
                  }`}>
                    {course.preco}
                  </p>
                  <p class="text-xs text-slate-600">
                    {course.parcelado}
                  </p>
                </div>

                <div class="flex gap-2">
                  <a 
                    href={course.link}
                    class={`flex-1 border border-black px-3 py-3 text-center text-sm font-bold uppercase tracking-[0.08em] transition-colors duration-300 ${
                      course.cor === 'primary' 
                        ? 'bg-[#ffcb00] text-black hover:bg-[#ffd633]' 
                        : 'bg-[#0619dd] text-white hover:bg-[#050f93]'
                    }`}
                  >
                    Ver Detalhes
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="material-surface py-14 md:py-16">
      <div class="section-wrap">
        <div class="editorial-card bg-[#ffcb00] p-8 text-center text-black md:p-10">
          <h2 class="font-['Space_Grotesk'] text-3xl uppercase leading-none md:text-4xl">
            Não sabe qual curso escolher?
          </h2>
          <p class="copy-limit text-pretty mx-auto mt-4 text-base leading-relaxed text-black md:text-lg">
            Fale com nossa equipe e receba orientação para selecionar o curso
            certo para seu perfil profissional.
          </p>
          <a
            href="https://wa.me/5517997572900?text=Olá! Gostaria de saber mais sobre os cursos da Autoescola Ideal."
            data-lead-action="open-modal"
            data-lead-source="cursos-help-cta"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 border border-black bg-black px-6 py-3 text-center text-sm font-bold uppercase tracking-[0.09em] text-white transition hover:bg-[#1f2937] sm:w-auto"
          >
            <span class="material-symbols-outlined">chat</span>
            Fale no WhatsApp
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- Schema Markup for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
</Layout>
