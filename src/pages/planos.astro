---
import Layout from "../layouts/Layout.astro";
import Calculator from "../components/calculator";
---

<Layout>
    <section id="calculadora" class="material-surface-strong py-14 md:py-20">
        <div class="section-wrap grid grid-cols-1 gap-4 lg:grid-cols-12">
            <header class="stagger-in editorial-card col-span-1 bg-[#050f93] p-5 text-white sm:p-6 md:p-8 lg:col-span-4">
                <p class="eyebrow text-[#ffcb00]">Simulador de Preços</p>
                <h1 class="headline-md mt-4 text-balance text-white">
                    Monte seu
                    <span class="text-[#ffcb00]">plano ideal</span>
                </h1>
                <p class="text-pretty mt-4 text-sm leading-relaxed text-white/95 md:text-base">
                    Ajuste tipo de habilitação, aulas e parcelas para visualizar
                    o valor estimado em tempo real.
                </p>
                <p class="mt-6 rounded-md border border-[#ffcb00]/55 bg-[#030b6f] px-4 py-3 text-xs uppercase tracking-[0.1em] text-white md:text-sm">
                    Arraste os controles e simule em segundos
                </p>
            </header>

            <div class="stagger-in stagger-delay-1 editorial-card col-span-1 bg-white p-3 sm:p-4 md:p-6 lg:col-span-8">
                <Calculator client:load />
            </div>
        </div>
    </section>
</Layout>
